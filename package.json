{
  "name": "vydex",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.11.1",
    "npm": "11.6.2"
  },
  "packageManager": "npm@11.6.2",
  "scripts": {
    "dev": "cross-env ASTRO_TELEMETRY_DISABLED=1 astro dev",
    "typecheck": "cross-env ASTRO_TELEMETRY_DISABLED=1 astro check",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "npm run typecheck && npm test && cross-env ASTRO_TELEMETRY_DISABLED=1 astro build",
    "preview": "cross-env ASTRO_TELEMETRY_DISABLED=1 astro preview",
    "test:browser:install": "playwright install chromium",
    "test:browser": "cross-env PUBLIC_SITE_ORIGIN=https://vydex.example npm run build && playwright test"
  },
  "dependencies": {
    "@fontsource-variable/source-sans-3": "5.2.9",
    "@fontsource-variable/source-serif-4": "5.2.9",
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "astro": "7.1.3",
    "remark-gfm": "4.0.1",
    "remark-mdx": "3.1.1",
    "remark-parse": "11.0.0",
    "unified": "11.0.5",
    "unist-util-visit": "5.1.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "@types/node": "24.13.3",
    "cross-env": "10.1.0",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  },
  "overrides": {
    "fast-uri": "3.1.4"
  }
}
